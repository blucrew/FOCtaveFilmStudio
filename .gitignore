# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# Audio/video working files (large, not for distribution)
*.wav
*.mp3
*.mp4
*.flac
*.m4a
*.ogg

# Generated funscripts (keep only in examples/ if committed explicitly)
*.funscript

# Comparison / scratch dirs
_compare/
_scratch/
_smoketest/
scratch/
out/

# Electrode placements (user-specific, generated from click tool)
*.electrodes.json
# ...except inside examples/, where they're part of the shipped demo
!examples/**/*.electrodes.json

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp
